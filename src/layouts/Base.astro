---
interface Props {
  titulo: string;
  descripcion?: string;
}

const { titulo, descripcion = 'Portfolio de Mohamed Chennani — Ingeniero Full Stack.' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={descripcion} />
    <title>{titulo}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Mono:ital,wght@0,400;0,500;1,400&family=Geist:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    
    <!-- Analytics removed -->
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --serif: 'Instrument Serif', Georgia, serif;
    --mono: 'DM Mono', monospace;
    --sans: 'Geist', system-ui, -apple-system, sans-serif;

    --color-bg: #ffffff;
    --color-text: #1a1a1a;
    --color-muted: #6b7280;
    --color-subtle: #9ca3af;
    --color-line: #e5e7eb;
    --color-surface: #f9fafb;
    --color-green: #16a34a;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --color-bg: #0f0f0f;
      --color-text: #f0f0f0;
      --color-muted: #9ca3af;
      --color-subtle: #6b7280;
      --color-line: #262626;
      --color-surface: #1a1a1a;
      --color-green: #4ade80;
    }
  }

  html {
    font-family: var(--sans);
    background-color: var(--color-bg);
    color: var(--color-text);
    font-size: 15px;
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
