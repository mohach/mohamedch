---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contacto — Mohamed Chennani"
  description="Contacta con Mohamed Chennani para proyectos freelance, colaboraciones o posiciones full-time."
>

  <section class="contact-hero">
    <div class="container">
      <div class="contact-hero__inner fade-in">
        <span class="tag">contacto</span>
        <h1 class="contact-hero__title">Hablemos</h1>
        <p class="contact-hero__desc">
          Estoy disponible para proyectos freelance, colaboraciones open source
          o posiciones full-time. Respondo en menos de 24 horas.
        </p>
      </div>
    </div>
  </section>

  <section class="contact-body">
    <div class="container">
      <div class="contact-grid">

        <!-- FORM -->
        <div class="contact-form-wrap fade-in">
          <form class="contact-form" id="contactForm" action="mailto:tu@email.com" method="POST" enctype="text/plain">
            <div class="form-group">
              <label class="form-label" for="name">Nombre</label>
              <input
                class="form-input"
                type="text"
                id="name"
                name="name"
                placeholder="Tu nombre"
                required
              />
            </div>

            <div class="form-group">
              <label class="form-label" for="email">Email</label>
              <input
                class="form-input"
                type="email"
                id="email"
                name="email"
                placeholder="tu@email.com"
                required
              />
            </div>

            <div class="form-group">
              <label class="form-label" for="subject">Asunto</label>
              <div class="select-wrap">
                <select class="form-input form-select" id="subject" name="subject">
                  <option value="">Selecciona un tipo de proyecto</option>
                  <option value="freelance">Proyecto freelance</option>
                  <option value="fulltime">Posición full-time</option>
                  <option value="collab">Colaboración open source</option>
                  <option value="consulting">Consultoría técnica</option>
                  <option value="other">Otro</option>
                </select>
                <svg class="select-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="6 9 12 15 18 9"/>
                </svg>
              </div>
            </div>

            <div class="form-group">
              <label class="form-label" for="message">Mensaje</label>
              <textarea
                class="form-input form-textarea"
                id="message"
                name="message"
                placeholder="Cuéntame sobre tu proyecto, stack tecnológico, plazos..."
                rows="5"
                required
              ></textarea>
            </div>

            <button type="submit" class="form-btn" id="submitBtn">
              <span class="form-btn__text">Enviar mensaje</span>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="22" y1="2" x2="11" y2="13"/>
                <polygon points="22 2 15 22 11 13 2 9 22 2"/>
              </svg>
            </button>

            <div class="form-note">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/>
                <line x1="12" y1="16" x2="12.01" y2="16"/>
              </svg>
              También puedes escribirme directamente a
              <a href="mailto:tu@email.com" class="form-note__link">tu@email.com</a>
            </div>
          </form>
        </div>

        <!-- ASIDE INFO -->
        <div class="contact-aside fade-in" style="animation-delay:0.15s">

          <div class="contact-info-card">
            <div class="info-card__header">
              <div class="status-dot"></div>
              <span class="info-card__status">Disponible para proyectos</span>
            </div>
            <p class="info-card__text">
              Actualmente acepto proyectos freelance y estoy abierto a ofertas de trabajo en remoto.
              Tiempo de respuesta habitual: <strong>menos de 24h</strong>.
            </p>
            <div class="info-card__details">
              <div class="info-detail">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"/>
                  <polyline points="12 6 12 12 16 14"/>
                </svg>
                <span>Zona horaria: CET (UTC+1)</span>
              </div>
              <div class="info-detail">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
                <span>España · Remoto worldwide</span>
              </div>
              <div class="info-detail">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                </svg>
                <span>Disponibilidad: 20–40h/semana</span>
              </div>
            </div>
          </div>

          <div class="contact-social">
            <span class="social-label">Encuéntrame en</span>
            <div class="social-links">
              <a href="https://github.com/tu-usuario" target="_blank" rel="noopener" class="social-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
                </svg>
                <div>
                  <span class="social-link__name">GitHub</span>
                  <span class="social-link__handle">@tu-usuario</span>
                </div>
                <svg class="social-arrow" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/>
                </svg>
              </a>

              <a href="https://linkedin.com/in/tu-perfil" target="_blank" rel="noopener" class="social-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
                <div>
                  <span class="social-link__name">LinkedIn</span>
                  <span class="social-link__handle">@tu-perfil</span>
                </div>
                <svg class="social-arrow" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/>
                </svg>
              </a>

              <a href="https://x.com/tu-usuario" target="_blank" rel="noopener" class="social-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
                <div>
                  <span class="social-link__name">X / Twitter</span>
                  <span class="social-link__handle">@tu-usuario</span>
                </div>
                <svg class="social-arrow" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/>
                </svg>
              </a>
            </div>
          </div>

          <div class="contact-faq">
            <span class="faq-label">Preguntas frecuentes</span>
            <div class="faq-list">
              <details class="faq-item">
                <summary class="faq-question">¿Cuánto cuesta un proyecto?</summary>
                <p class="faq-answer">Depende del alcance. Trabajo por horas (€60–90/h) o precio fijo por proyecto. Contacta con los detalles y te envío un presupuesto sin compromiso.</p>
              </details>
              <details class="faq-item">
                <summary class="faq-question">¿Trabajas en remoto?</summary>
                <p class="faq-answer">Sí, trabajo 100% en remoto. Tengo experiencia colaborando con equipos en diferentes zonas horarias (Europa, América).</p>
              </details>
              <details class="faq-item">
                <summary class="faq-question">¿Cuál es tu stack preferido?</summary>
                <p class="faq-answer">Astro, React, TypeScript y Node.js para la mayoría de proyectos web. Pero me adapto al stack del equipo.</p>
              </details>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .contact-hero {
    padding-top: 120px;
    padding-bottom: 3rem;
    border-bottom: 0.5px solid var(--border);
    margin-bottom: 3rem;
  }

  .contact-hero__inner {
    max-width: 560px;
  }

  .contact-hero__title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin: 0.75rem 0 1rem;
  }

  .contact-hero__desc {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.75;
  }

  .contact-body {
    padding-bottom: 6rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 3rem;
    align-items: start;
  }

  /* FORM */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .form-input {
    background: var(--surface);
    border: 0.5px solid var(--border-strong);
    border-radius: var(--radius-md);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 0.9rem;
    padding: 11px 14px;
    width: 100%;
    transition: border-color var(--transition), box-shadow var(--transition);
    outline: none;
    -webkit-appearance: none;
  }

  .form-input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-glow);
  }

  .form-input::placeholder {
    color: var(--text-muted);
  }

  .form-textarea {
    resize: vertical;
    min-height: 130px;
    font-family: var(--font-body);
    line-height: 1.65;
  }

  .select-wrap {
    position: relative;
  }

  .form-select {
    cursor: pointer;
    padding-right: 36px;
    appearance: none;
    -webkit-appearance: none;
    background: var(--surface);
  }

  .select-arrow {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
    pointer-events: none;
  }

  .form-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 600;
    padding: 12px 24px;
    cursor: pointer;
    transition: all var(--transition);
    width: 100%;
    margin-top: 0.25rem;
  }

  .form-btn:hover {
    background: var(--accent-muted);
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(14,165,233,0.3);
  }

  .form-btn:active {
    transform: translateY(0);
  }

  .form-note {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.78rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  .form-note svg { flex-shrink: 0; }

  .form-note__link {
    color: var(--accent);
    transition: color var(--transition);
  }

  .form-note__link:hover { text-decoration: underline; }

  /* ASIDE */
  .contact-aside {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: sticky;
    top: 80px;
  }

  .contact-info-card {
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
  }

  .info-card__header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 0.75rem;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #22c55e;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(0.85); }
  }

  .info-card__status {
    font-size: 0.85rem;
    font-weight: 600;
    color: #22c55e;
  }

  .info-card__text {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.65;
    margin-bottom: 1rem;
  }

  .info-card__details {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .info-detail {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.8rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  .info-detail svg { flex-shrink: 0; }

  /* SOCIAL */
  .contact-social {
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
  }

  .social-label {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--text-muted);
    display: block;
    margin-bottom: 1rem;
  }

  .social-links {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 0.5px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
    border-bottom: 0.5px solid var(--border);
    color: var(--text-secondary);
    transition: background var(--transition), color var(--transition);
  }

  .social-link:last-child { border-bottom: none; }

  .social-link:hover {
    background: var(--surface-hover);
    color: var(--text-primary);
  }

  .social-link svg:first-child { flex-shrink: 0; }

  .social-link__name {
    display: block;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-primary);
  }

  .social-link__handle {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .social-arrow {
    margin-left: auto;
    color: var(--text-muted);
    transition: transform var(--transition), color var(--transition);
  }

  .social-link:hover .social-arrow {
    color: var(--accent);
    transform: translate(2px, -2px);
  }

  /* FAQ */
  .contact-faq {
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
  }

  .faq-label {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--text-muted);
    display: block;
    margin-bottom: 1rem;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 0.5px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .faq-item {
    border-bottom: 0.5px solid var(--border);
  }

  .faq-item:last-child { border-bottom: none; }

  .faq-question {
    padding: 12px 14px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-primary);
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: background var(--transition);
  }

  .faq-question::-webkit-details-marker { display: none; }

  .faq-question::after {
    content: '+';
    color: var(--text-muted);
    font-size: 1rem;
    font-weight: 300;
    transition: transform var(--transition);
  }

  .faq-item[open] .faq-question::after {
    transform: rotate(45deg);
  }

  .faq-question:hover { background: var(--surface-hover); }

  .faq-answer {
    padding: 0 14px 12px;
    font-size: 0.82rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
    .contact-aside {
      position: static;
    }
  }
</style>

<script>
  const form = document.getElementById('contactForm') as HTMLFormElement;
  const btn = document.getElementById('submitBtn');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const name = (document.getElementById('name') as HTMLInputElement).value;
    const email = (document.getElementById('email') as HTMLInputElement).value;
    const subject = (document.getElementById('subject') as HTMLSelectElement).value;
    const message = (document.getElementById('message') as HTMLTextAreaElement).value;

    const mailtoLink = `mailto:tu@email.com?subject=${encodeURIComponent(subject || 'Contacto desde web')}&body=${encodeURIComponent(`Nombre: ${name}\nEmail: ${email}\n\n${message}`)}`;
    window.location.href = mailtoLink;
  });
</script>
