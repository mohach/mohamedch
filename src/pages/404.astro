---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="404 — Mohamed Chennani" lang="en">
  <div class="nf">
    <div class="container">
      <p class="label">404</p>
      <h1 class="nf-title">Page not found</h1>
      <p class="nf-desc">This page doesn't exist or was moved.</p>
      <a href="/" class="btn btn-primary">Go home</a>
    </div>
  </div>
</BaseLayout>
<style>
.nf{min-height:80vh;display:flex;align-items:center;padding-top:var(--nav-h);}
.nf .container{display:flex;flex-direction:column;align-items:flex-start;gap:1.25rem;}
.nf-title{font-size:clamp(2rem,5vw,3.5rem);letter-spacing:-0.025em;}
.nf-desc{font-size:1rem;color:var(--text-2);}
</style>
