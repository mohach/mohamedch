---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

function formatFecha(fecha: Date): string {
  return fecha.toLocaleDateString('es-ES', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}
---

<Base titulo={`${post.data.titulo} — Mohamed Chennani`} descripcion={post.data.descripcion}>
  <main class="container">
    <Nav paginaActual="blog" />

    <article>
      <header class="post-header">
        <div class="post-meta">
          <span class="post-fecha">{formatFecha(post.data.fecha)}</span>
          <span class="separador">·</span>
          <a href="/blog" class="post-etiqueta">{post.data.etiqueta}</a>
        </div>
        <h1>{post.data.titulo}</h1>
        <p class="post-desc">{post.data.descripcion}</p>
      </header>

      <div class="contenido">
        <Content />
      </div>

      <footer class="post-footer">
        <a href="/blog" class="volver">← volver al blog</a>
      </footer>
    </article>
  </main>
</Base>

<style>
  .container {
    max-width: 680px;
    margin: 0 auto;
    padding: 3rem 1.5rem 6rem;
  }

  /* HEADER DEL POST */
  .post-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 0.5px solid var(--color-line);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--color-subtle);
  }

  .separador {
    color: var(--color-line);
  }

  .post-etiqueta {
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .post-etiqueta:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  .post-header h1 {
    font-family: var(--serif);
    font-size: clamp(1.7rem, 4vw, 2.2rem);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin-bottom: 0.85rem;
  }

  .post-desc {
    font-size: 16px;
    color: var(--color-muted);
    line-height: 1.65;
    font-style: italic;
  }

  /* CONTENIDO MARKDOWN */
  .contenido {
    font-size: 15.5px;
    line-height: 1.75;
    color: var(--color-text);
  }

  .contenido :global(h2) {
    font-family: var(--serif);
    font-size: 1.5rem;
    font-weight: 400;
    margin: 2.5rem 0 0.85rem;
    color: var(--color-text);
  }

  .contenido :global(h3) {
    font-size: 1rem;
    font-weight: 500;
    margin: 2rem 0 0.6rem;
    font-family: var(--mono);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 12px;
    color: var(--color-muted);
  }

  .contenido :global(p) {
    margin-bottom: 1.25rem;
    color: var(--color-muted);
  }

  .contenido :global(strong) {
    color: var(--color-text);
    font-weight: 500;
  }

  .contenido :global(a) {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .contenido :global(ul),
  .contenido :global(ol) {
    margin: 0 0 1.25rem 1.25rem;
    color: var(--color-muted);
  }

  .contenido :global(li) {
    margin-bottom: 0.35rem;
  }

  .contenido :global(code) {
    font-family: var(--mono);
    font-size: 13px;
    background: var(--color-surface);
    border: 0.5px solid var(--color-line);
    padding: 1px 5px;
    border-radius: 3px;
  }

  .contenido :global(pre) {
    background: var(--color-surface);
    border: 0.5px solid var(--color-line);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    margin: 0 0 1.5rem;
  }

  .contenido :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: 13px;
    line-height: 1.65;
  }

  .contenido :global(blockquote) {
    border-left: 2px solid var(--color-line);
    padding-left: 1.25rem;
    margin: 0 0 1.25rem;
    color: var(--color-muted);
    font-style: italic;
  }

  .contenido :global(hr) {
    border: none;
    border-top: 0.5px solid var(--color-line);
    margin: 2rem 0;
  }

  /* FOOTER */
  .post-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 0.5px solid var(--color-line);
  }

  .volver {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .volver:hover {
    color: var(--color-text);
    text-decoration: none;
  }
</style>
