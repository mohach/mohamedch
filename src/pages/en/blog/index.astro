---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import { ui } from '../../../i18n';

const t = ui.en;

const files = await Astro.glob('../../../content/blog/*.md');

const posts = files
  .filter((f: any) => f.frontmatter.lang === 'en')
  .map((f: any) => ({
    title:    f.frontmatter.title    ?? 'No title',
    excerpt:  f.frontmatter.excerpt  ?? '',
    date:     f.frontmatter.date     ?? '',
    slug:     f.frontmatter.slug     ?? '',
    tags:     Array.isArray(f.frontmatter.tags) ? f.frontmatter.tags : [],
    readTime: '5 min read',
  }))
  .sort((a: any, b: any) => b.date.localeCompare(a.date));
---

<BaseLayout title="Blog — Mohamed Chennani" lang="en"
  description="Technical articles on Linux, networking, Cloudflare, streaming and web administration.">

  <div style="padding-top:var(--nav-h)"></div>

  <section class="section">
    <div class="container">
      <SectionHeader label={t.blog.label} title={t.blog.title} sub={t.blog.sub} />

      {posts.length === 0 ? (
        <p class="empty">{t.blog.noPost}</p>
      ) : (
        <div class="blist">
          {posts.map((p: any, i: number) => (
            <a href={`/en/blog/${p.slug}`} class="brow reveal" style={`transition-delay:${i*0.06}s`}>
              <div class="brow-meta">
                <time class="label">{p.date}</time>
                <span class="label brow-rt">{p.readTime}</span>
              </div>
              <h3 class="brow-title">{p.title}</h3>
              <p class="brow-exc">{p.excerpt}</p>
              <div class="brow-foot">
                <div class="brow-tags">{p.tags.map((tag: string) => <span class="tag">{tag}</span>)}</div>
                <span class="brow-arr">→</span>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

</BaseLayout>

<style>
.empty{padding:3rem 0;color:var(--text-2);}
.blist{border-top:1px solid var(--border);}
.brow{display:flex;flex-direction:column;gap:0.65rem;padding:1.75rem 0;border-bottom:1px solid var(--border);color:inherit;}
.brow-meta{display:flex;align-items:center;gap:1rem;}
.brow-rt::before{content:'·';margin-right:1rem;}
.brow-title{font-family:var(--font-serif);font-size:clamp(1.05rem,1.8vw,1.3rem);font-weight:400;color:var(--text);transition:opacity 0.15s;}
.brow:hover .brow-title{opacity:0.6;}
.brow-exc{font-size:0.875rem;color:var(--text-2);line-height:1.65;}
.brow-foot{display:flex;align-items:center;justify-content:space-between;gap:1rem;margin-top:0.25rem;}
.brow-tags{display:flex;flex-wrap:wrap;gap:5px;}
.brow-arr{color:var(--text-3);font-size:1rem;transition:transform 0.2s,color 0.15s;flex-shrink:0;}
.brow:hover .brow-arr{transform:translateX(5px);color:var(--text);}
</style>
