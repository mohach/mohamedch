---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CV from '../../components/CV.astro';
import { ui, personal } from '../../i18n.ts';

const t = ui.en;
const p = personal;
---

<BaseLayout title={`${p.name} — Curriculum Vitae`} lang="en"
  description="Curriculum Vitae of Mohamed Chennani — IT Technician with over 10 years of experience in Linux, networking, Cloudflare and streaming/IPTV.">

  <div class="cv-page">
    <!-- Header with buttons -->
    <div class="cv-header-actions">
      <div>
        <h1>Curriculum Vitae</h1>
        <p class="cv-subtitle">Professional A4 format ready to print</p>
      </div>
      <div class="cv-buttons">
        <button onclick="window.print()" class="btn btn-primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="6 9 6 2 18 2 18 9"></polyline>
            <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path>
            <rect x="6" y="14" width="12" height="8"></rect>
          </svg>
          Print / Save PDF
        </button>
        <a href="/en" class="btn btn-ghost">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          Back to site
        </a>
      </div>
    </div>

    <!-- Instructions -->
    <div class="cv-instructions">
      <div class="instruction">
        <div class="instruction-icon">💡</div>
        <div>
          <h3>To download as PDF:</h3>
          <p>Click <strong>"Print / Save PDF"</strong> → Select <strong>"Save as PDF"</strong> as printer → Set margins to <strong>"None"</strong> → Download.</p>
        </div>
      </div>
      <div class="instruction">
        <div class="instruction-icon">📄</div>
        <div>
          <h3>A4 Format:</h3>
          <p>This CV is optimized for A4 paper (210×297mm). It will look perfect when printed or converted to PDF.</p>
        </div>
      </div>
      <div class="instruction">
        <div class="instruction-icon">🔄</div>
        <div>
          <h3>Automatic updates:</h3>
          <p>This CV updates automatically when I modify my website. You'll always have the latest version.</p>
        </div>
      </div>
    </div>

    <!-- The CV itself -->
    <div class="cv-preview">
      <CV />
    </div>

    <!-- Buttons at the bottom -->
    <div class="cv-footer-actions">
      <button onclick="window.print()" class="btn btn-primary btn-large">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="6 9 6 2 18 2 18 9"></polyline>
          <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a22 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path>
          <rect x="6" y="14" width="12" height="8"></rect>
        </svg>
        Download CV as PDF
      </button>
      <p class="cv-note">
        You can also <a href="javascript:window.print()">print directly</a> or 
        <a href="/en/contact">contact me</a> if you need a customized version.
      </p>
    </div>
  </div>

  <style>
    .cv-page {
      padding: calc(var(--nav-h) + 2rem) 0 4rem;
      max-width: 1200px;
      margin: 0 auto;
      min-height: 100vh;
    }

    .cv-header-actions {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 2.5rem;
      flex-wrap: wrap;
      gap: 1.5rem;
      padding-top: 1rem;
    }

    .cv-header-actions h1 {
      font-size: 2.5rem;
      letter-spacing: -0.02em;
      margin: 0;
    }

    .cv-subtitle {
      color: var(--text-2);
      margin-top: 0.5rem;
      font-size: 1rem;
    }

    .cv-buttons {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    .cv-buttons .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 20px;
    }

    .cv-instructions {
      background: var(--bg-alt);
      border: 1px solid var(--border);
      border-radius: var(--r-lg);
      padding: 2rem;
      margin-bottom: 3rem;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
    }

    .instruction {
      display: flex;
      gap: 1rem;
      align-items: flex-start;
    }

    .instruction-icon {
      font-size: 1.5rem;
      flex-shrink: 0;
      margin-top: 2px;
    }

    .instruction h3 {
      font-size: 1rem;
      margin: 0 0 0.5rem 0;
      color: var(--text);
    }

    .instruction p {
      font-size: 0.9rem;
      color: var(--text-2);
      line-height: 1.5;
      margin: 0;
    }

    .cv-preview {
      background: white;
      border-radius: var(--r-lg);
      box-shadow: 0 10px 40px rgba(0,0,0,0.1);
      margin-bottom: 3rem;
      overflow: hidden;
      border: 1px solid var(--border);
    }

    .cv-footer-actions {
      text-align: center;
      padding: 2rem;
      background: var(--bg-alt);
      border-radius: var(--r-lg);
      border: 1px solid var(--border);
    }

    .btn-large {
      padding: 14px 28px;
      font-size: 1.05rem;
      font-weight: 600;
    }

    .btn-large svg {
      width: 20px;
      height: 20px;
    }

    .cv-note {
      margin-top: 1.5rem;
      font-size: 0.9rem;
      color: var(--text-2);
    }

    .cv-note a {
      color: var(--text);
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .cv-note a:hover {
      color: var(--text-2);
    }

    /* Print styles */
    @media print {
      .cv-header-actions,
      .cv-instructions,
      .cv-footer-actions,
      .nav,
      .footer,
      .waf,
      #printLoader {
        display: none !important;
      }
      
      .cv-page {
        padding: 0 !important;
        margin: 0 !important;
        max-width: 100% !important;
        min-height: auto !important;
      }
      
      .cv-preview {
        box-shadow: none !important;
        border: none !important;
        border-radius: 0 !important;
        margin: 0 !important;
      }
      
      /* Optimize for A4 */
      @page {
        size: A4;
        margin: 15mm;
      }
      
      body {
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
        background: white !important;
        color: black !important;
      }
    }
    
    /* Print mode (before printing) */
    body.print-mode * {
      animation: none !important;
      transition: none !important;
    }
    
    body.print-mode .cv-preview {
      transform: none !important;
      opacity: 1 !important;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .cv-header-actions {
        flex-direction: column;
      }
      
      .cv-buttons {
        width: 100%;
      }
      
      .cv-buttons .btn {
        flex: 1;
        justify-content: center;
      }
      
      .cv-instructions {
        grid-template-columns: 1fr;
        padding: 1.5rem;
      }
      
      .cv-header-actions h1 {
        font-size: 2rem;
      }
    }
  </style>

  <script>
    // Improve printing experience
    document.addEventListener('DOMContentLoaded', () => {
      // Function to show loader
      function showPrintLoader() {
        const loader = document.createElement('div');
        loader.id = 'printLoader';
        loader.innerHTML = `
          <div style="position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.7);z-index:9999;display:flex;align-items:center;justify-content:center;">
            <div style="background:white;padding:2rem;border-radius:12px;text-align:center;max-width:400px;">
              <div style="font-size:3rem;margin-bottom:1rem;">🖨️</div>
              <h3 style="margin:0 0 1rem 0;">Preparing print...</h3>
              <p style="color:#666;margin:0 0 1.5rem 0;">This may take a few seconds. Select <strong>"Save as PDF"</strong> as printer.</p>
              <div style="display:flex;gap:0.5rem;justify-content:center;">
                <button onclick="document.getElementById('printLoader').remove();" style="padding:8px 16px;border:1px solid #ddd;background:white;border-radius:6px;cursor:pointer;">Cancel</button>
              </div>
            </div>
          </div>
        `;
        document.body.appendChild(loader);
        
        // Auto-remove after 10 seconds
        setTimeout(() => {
          if (document.getElementById('printLoader')) {
            document.getElementById('printLoader').remove();
          }
        }, 10000);
      }
      
      // Optimized print function
      function optimizedPrint() {
        // Show loader
        showPrintLoader();
        
        // Disable animations before printing
        document.body.classList.add('print-mode');
        
        // Small delay for styles to apply
        setTimeout(() => {
          // Try to print
          window.print();
          
          // Remove loader after a while
          setTimeout(() => {
            if (document.getElementById('printLoader')) {
              document.getElementById('printLoader').remove();
            }
            document.body.classList.remove('print-mode');
          }, 1000);
        }, 100);
      }
      
      // Replace all print buttons
      document.querySelectorAll('[onclick="window.print()"]').forEach(btn => {
        // Remove original onclick
        btn.removeAttribute('onclick');
        
        // Add new event
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          optimizedPrint();
        });
      });
      
      // Also replace links with javascript:window.print()
      document.querySelectorAll('a[href^="javascript:window.print"]').forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          optimizedPrint();
        });
      });
      
      // Native print events
      window.addEventListener('beforeprint', () => {
        document.body.classList.add('printing');
        // Hide loader if still visible
        if (document.getElementById('printLoader')) {
          document.getElementById('printLoader').remove();
        }
      });
      
      window.addEventListener('afterprint', () => {
        document.body.classList.remove('printing');
        document.body.classList.remove('print-mode');
      });
    });
  </script>
</BaseLayout>