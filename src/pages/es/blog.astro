---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import { ui } from '../../i18n';
const t = ui.es;

const posts = [
  { title: 'Cómo monté una infraestructura IPTV completa en un VPS', excerpt: 'Paso a paso: configuración del VPS, codificación con FFmpeg, ingest SRS, empaquetado HLS y distribución con Cloudflare CDN.', date: 'Ene 2025', tags: ['Linux','Streaming','Cloudflare'], href: '#', readTime: '8 min' },
  { title: 'Guía de configuración de Cloudflare para sitios WordPress', excerpt: 'DNS, reglas de caché, reglas de página, firewall y consejos de rendimiento para sacar el máximo partido a Cloudflare en WordPress.', date: 'Nov 2024', tags: ['WordPress','Cloudflare','Redes'], href: '#', readTime: '6 min' },
  { title: 'Hardening de servidor Linux: mi checklist', excerpt: 'Claves SSH, UFW, fail2ban, actualizaciones automáticas y monitorización — los pasos que sigo en cada nuevo servidor.', date: 'Sep 2024', tags: ['Linux','Seguridad','SSH'], href: '#', readTime: '7 min' },
  { title: 'Nginx como reverse proxy con SSL en Ubuntu', excerpt: "Let's Encrypt, Certbot y configuración de virtualhost Nginx para servir múltiples dominios en un solo VPS con HTTPS automático.", date: 'Jul 2024', tags: ['Nginx','Linux','SSL'], href: '#', readTime: '5 min' },
];
---
<BaseLayout title="Blog — Mohamed Chennani" lang="es" description="Artículos técnicos sobre Linux, redes, Cloudflare, streaming y WordPress.">
  <div style="padding-top:var(--nav-h)"></div>
  <section class="section">
    <div class="container">
      <SectionHeader label={t.blog.label} title={t.blog.title} sub={t.blog.sub} />
      <div class="blist">
        {posts.map((p, i) => (
          <a href={p.href} class="brow reveal" style={`transition-delay:${i*0.06}s`}>
            <div class="brow-meta">
              <time class="label">{p.date}</time>
              <span class="label brow-rt">{p.readTime}</span>
            </div>
            <h3 class="brow-title">{p.title}</h3>
            <p class="brow-exc">{p.excerpt}</p>
            <div class="brow-foot">
              <div class="brow-tags">{p.tags.map(t => <span class="tag">{t}</span>)}</div>
              <span class="brow-arr">→</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
<style>
.blist { border-top:1px solid var(--border); }
.brow { display:flex; flex-direction:column; gap:0.65rem; padding:1.75rem 0; border-bottom:1px solid var(--border); color:inherit; }
.brow-meta { display:flex; align-items:center; gap:1rem; }
.brow-rt::before { content:'·'; margin-right:1rem; }
.brow-title { font-family:var(--font-serif); font-size:clamp(1.05rem,1.8vw,1.25rem); font-weight:400; color:var(--text); transition:opacity 0.15s; }
.brow:hover .brow-title { opacity:0.6; }
.brow-exc { font-size:0.875rem; color:var(--text-2); line-height:1.65; }
.brow-foot { display:flex; align-items:center; justify-content:space-between; gap:1rem; margin-top:0.25rem; }
.brow-tags { display:flex; flex-wrap:wrap; gap:5px; }
.brow-arr { color:var(--text-3); font-size:1rem; transition:transform 0.2s,color 0.15s; flex-shrink:0; }
.brow:hover .brow-arr { transform:translateX(5px); color:var(--text); }
</style>
