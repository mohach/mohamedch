---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { ui } from '../i18n';
const t = ui.en;

const posts = [
  { title: 'How I set up a full IPTV streaming stack on a VPS', excerpt: 'Step-by-step: VPS setup, FFmpeg encoding, SRS ingest, HLS packaging, and Cloudflare CDN delivery for stable multi-viewer streams.', date: 'Jan 2025', tags: ['Linux','Streaming','Cloudflare'], href: '#', readTime: '8 min' },
  { title: 'Cloudflare setup guide for WordPress sites', excerpt: 'DNS, caching rules, page rules, firewall, and performance tips for getting the most out of Cloudflare on a WordPress site.', date: 'Nov 2024', tags: ['WordPress','Cloudflare','Networking'], href: '#', readTime: '6 min' },
  { title: 'Linux server hardening: my checklist', excerpt: 'SSH keys, UFW firewall rules, fail2ban, automatic updates, and monitoring — the steps I follow on every new server.', date: 'Sep 2024', tags: ['Linux','Security','SSH'], href: '#', readTime: '7 min' },
  { title: 'Setting up Nginx as a reverse proxy with SSL', excerpt: "Let's Encrypt, Certbot, and Nginx virtualhost config for serving multiple domains on a single VPS with automatic HTTPS renewal.", date: 'Jul 2024', tags: ['Nginx','Linux','SSL'], href: '#', readTime: '5 min' },
];
---
<BaseLayout title="Blog — Mohamed Chennani" lang="en" description="Technical articles on Linux, networking, Cloudflare, streaming, and WordPress.">
  <div style="padding-top:var(--nav-h)"></div>
  <section class="section">
    <div class="container">
      <SectionHeader label={t.blog.label} title={t.blog.title} sub={t.blog.sub} />
      <div class="blist">
        {posts.map((p, i) => (
          <a href={p.href} class="brow reveal" style={`transition-delay:${i*0.06}s`}>
            <div class="brow-meta">
              <time class="label">{p.date}</time>
              <span class="label brow-rt">{p.readTime}</span>
            </div>
            <h3 class="brow-title">{p.title}</h3>
            <p class="brow-exc">{p.excerpt}</p>
            <div class="brow-foot">
              <div class="brow-tags">{p.tags.map(t => <span class="tag">{t}</span>)}</div>
              <span class="brow-arr">→</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
<style>
.blist { border-top: 1px solid var(--border); }
.brow { display: flex; flex-direction: column; gap: 0.65rem; padding: 1.75rem 0; border-bottom: 1px solid var(--border); color: inherit; }
.brow-meta { display: flex; align-items: center; gap: 1rem; }
.brow-rt::before { content:'·'; margin-right:1rem; }
.brow-title { font-family: var(--font-serif); font-size: clamp(1.05rem,1.8vw,1.25rem); font-weight:400; color:var(--text); transition:opacity 0.15s; }
.brow:hover .brow-title { opacity:0.6; }
.brow-exc { font-size:0.875rem; color:var(--text-2); line-height:1.65; }
.brow-foot { display:flex; align-items:center; justify-content:space-between; gap:1rem; margin-top:0.25rem; }
.brow-tags { display:flex; flex-wrap:wrap; gap:5px; }
.brow-arr { color:var(--text-3); font-size:1rem; transition:transform 0.2s, color 0.15s; flex-shrink:0; }
.brow:hover .brow-arr { transform:translateX(5px); color:var(--text); }
</style>
